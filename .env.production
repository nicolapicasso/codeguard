# ── Server ──────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# ── Database (Digital Ocean managed DB URL) ─────────────────
# On App Platform this is injected automatically via ${db.DATABASE_URL}
DATABASE_URL=postgresql://USER:PASSWORD@HOST:25060/DB?sslmode=require

# ── Redis (Digital Ocean managed Redis URL) ─────────────────
# On App Platform this is injected automatically via ${redis.REDIS_URL}
REDIS_URL=rediss://default:PASSWORD@HOST:25061

# ── Auth ────────────────────────────────────────────────────
# IMPORTANT: Generate a strong secret: openssl rand -base64 48
JWT_SECRET=CHANGE_ME
HMAC_TOLERANCE_SECONDS=300

# ── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_PER_USER_PER_MINUTE=30
RATE_LIMIT_PER_IP_PER_MINUTE=100

# ── Security ────────────────────────────────────────────────
STORE_PLAIN_CODES=false
CUSTOM_FUNCTION_TIMEOUT_MS=100

# ── Deploy ──────────────────────────────────────────────────
# Set to "true" on first deploy to seed demo data, then disable
SEED_ON_DEPLOY=false
